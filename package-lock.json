// src/routes/history.js
//
// Lists and retrieves past research runs, persisted by src/db.js. This is
// what makes past demo/research sessions durable across server restarts,
// rather than disappearing the moment you close the browser tab.

const express = require("express");
const db = require("../db");
const { asyncRoute } = require("../middleware/errorHandler");

const router = express.Router();

router.get(
  "/history",
  asyncRoute(async (req, res) => {
    const limit = Math.min(parseInt(req.query.limit, 10) || 20, 100);
    const offset = parseInt(req.query.offset, 10) || 0;
    res.json(db.listRuns({ limit, offset }));
  })
);

router.get(
  "/history/:id",
  asyncRoute(async (req, res) => {
    const run = db.getRun(req.params.id);
    if (!run) return res.status(404).json({ error: "Run not found." });
    res.json(run);
  })
);

module.exports = router;
