const test = require("node:test");
const assert = require("node:assert");
const fs = require("fs");
const path = require("path");
const os = require("os");

// Point config at a throwaway history file before requiring db.js, so tests
// never touch the real data/history.json.
const tmpFile = path.join(os.tmpdir(), `eq-terminal-test-${Date.now()}.json`);
process.env.HISTORY_FILE = tmpFile;

const db = require("../src/db");

test("saveRun + listRuns + getRun round-trip", () => {
  const run = {
    id: "test-id-1",
    createdAt: new Date().toISOString(),
    companies: ["TestCo"],
    demoMode: true,
    results: { TestCo: { company: "TestCo" } },
  };

  db.saveRun(run);

  const { total, runs } = db.listRuns({ limit: 10, offset: 0 });
  assert.ok(total >= 1);
  assert.strictEqual(runs[0].id, "test-id-1");
  assert.strictEqual(runs[0].companies[0], "TestCo");
  // summarize() should not include the full results payload
  assert.strictEqual(runs[0].results, undefined);

  const full = db.getRun("test-id-1");
  assert.ok(full);
  assert.strictEqual(full.results.TestCo.company, "TestCo");
});

test("getRun returns null for unknown id", () => {
  const result = db.getRun("does-not-exist");
  assert.strictEqual(result, null);
});

test.after(() => {
  if (fs.existsSync(tmpFile)) fs.unlinkSync(tmpFile);
});
